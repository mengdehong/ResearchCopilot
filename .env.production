# ============= Database =============
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/research_copilot
REDIS_URL=redis://redis:6379/0

# ============= Auth =============
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256

# ============= LLM =============
OPENAI_API_KEY=sk-xxx
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# ============= Storage =============
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=research-copilot

# ============= Sandbox =============
SANDBOX_IMAGE=research-copilot-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=120
SANDBOX_MEMORY_LIMIT=4g
SANDBOX_CPU_COUNT=2

# ============= Celery =============
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ============= LangGraph =============
LANGGRAPH_SERVER_URL=http://langgraph-server:8123

# ============= MinerU =============
MINERU_API_URL=https://mineru.net/api/v4
MINERU_API_KEY=your-mineru-api-key
